# Outfit AI Environment Variables Template
# Copy this file to .env and fill in your actual values

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Storage
GCS_BUCKET_NAME=your_gcs_bucket_name
GOOGLE_APPLICATION_CREDENTIALS=path_to_your_gcs_key.json

# Google Cloud Project (for Vertex AI)
GCP_PROJECT_ID=your_gcp_project_id
GCP_LOCATION=us-central1

# JWT Secret Key (generate a secure random string)
JWT_SECRET_KEY=your_super_secure_jwt_secret_key_at_least_32_chars_long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=sqlite:///./outfitai.db

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=standard
# LOG_FORMAT=json  # Use json for production

# Vector Database
VECTOR_DB_DIR=./vector_db_data

# Weather API (OpenWeather)
OPENWEATHER_API_KEY=your_openweather_api_key_here

